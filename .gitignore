# Generated key-provisioning output — must never be committed.
/provisioning/

# Defense in depth: any private-key-shaped file, anywhere in the repo.
*.key
*.pem
*-private
*-private.*
*_private_key*

# Python bytecode cache
__pycache__/
*.pyc

# Local mirror zip build output (uploaded as GitHub release assets)
/mirrors/

# Isolated build output for the pinned Numan parser compatibility check.
/tools/numan-parser-check/target/

# Hook runtime artifacts and cache
/.mrge/
