{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/tonythethompson/numan-registry/schemas/index-v1.json",
  "title": "Numan Registry Index v1",
  "description": "Schema for the signed Numan registry index.",
  "type": "object",
  "required": ["schema_version", "updated_at", "packages"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1,
      "description": "Registry index schema version. Must be 1."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last index update."
    },
    "registry_revision": {
      "type": "string",
      "description": "Opaque registry revision identifier."
    },
    "trust": {
      "type": "object",
      "description": "Successor key declarations introduced by a signed index.",
      "additionalProperties": false,
      "properties": {
        "keys": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key_id", "public_key_b64"],
            "additionalProperties": false,
            "properties": {
              "key_id": {
                "type": "string",
                "minLength": 1
              },
              "public_key_b64": {
                "type": "string",
                "contentEncoding": "base64"
              }
            }
          }
        }
      }
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "repo", "type", "tags", "versions"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "object",
            "required": ["owner", "name"],
            "additionalProperties": false,
            "properties": {
              "owner": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 }
            }
          },
          "description": { "type": "string" },
          "repo": { "type": "string", "format": "uri" },
          "type": {
            "type": "string",
            "enum": ["plugin", "module", "script", "completion"]
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "versions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["version", "nu_version", "artifact"],
              "additionalProperties": false,
              "properties": {
                "version": { "type": "string" },
                "nu_version": { "type": "string" },
                "verified_with": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "artifact": {
                  "type": "object",
                  "required": ["kind"],
                  "additionalProperties": false,
                  "properties": {
                    "kind": {
                      "type": "string",
                      "enum": ["binary", "archive", "source"]
                    },
                    "url": { "type": "string", "format": "uri" },
                    "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
                    "targets": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "required": ["url", "sha256", "executable_path"],
                        "additionalProperties": false,
                        "properties": {
                          "url": { "type": "string", "format": "uri" },
                          "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
                          "executable_path": { "type": "string" }
                        }
                      }
                    },
                    "archive_root": { "type": "string" },
                    "include": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "entry": { "type": "string" }
                  }
                },
                "source": {
                  "type": "object",
                  "required": ["git", "rev", "cargo_name"],
                  "additionalProperties": false,
                  "properties": {
                    "git": { "type": "string" },
                    "rev": { "type": "string" },
                    "cargo_name": { "type": "string" },
                    "cargo_lock_sha256": { "type": "string" }
                  }
                },
                "dependencies": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "activation": {
                  "type": "object",
                  "required": ["kind"],
                  "additionalProperties": false,
                  "properties": {
                    "kind": { "type": "string" },
                    "import": { "type": "string", "enum": ["module", "all"] }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
