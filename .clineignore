# Cline context exclusions for numan-registry
# Data-only repository: JSON registry index, schemas, signing keys, and CI scripts.
# Preserve registry data, schemas, docs, scripts, and CI configuration.

# Python dependencies and caches
/node_modules/
**/node_modules/
/vendor/
.venv/
venv/
env/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Build outputs
/dist/
**/dist/
/build/
**/build/
/out/
**/out/
/coverage/
**/coverage/
*.wasm
*.dll
*.exe
*.so
*.dylib
*.pdb

# Large media, archives, binaries, databases, and datasets
*.mp3
*.wav
*.flac
*.ogg
*.m4a
*.mp4
*.mkv
*.mov
*.avi
*.webm
*.zip
*.7z
*.rar
*.tar
*.gz
*.bz2
*.xz
*.npy
*.npz
*.h5
*.hdf5
*.onnx
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
/models/
/weights/
/checkpoints/
/datasets/
/artifacts/

# Logs, caches, operating-system files, and IDE metadata
*.log
logs/
*.cache
.cache/
.npm/
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Local environment and machine-specific configuration
.env
.env.*
!.env.example
!.env.template
*.local

# Dependency lockfiles
package-lock.json
npm-shrinkwrap.json
yarn.lock
pnpm-lock.yaml
bun.lockb
poetry.lock
Pipfile.lock
uv.lock
Gemfile.lock
composer.lock
Cargo.lock
Podfile.lock
Package.resolved

# AI assistant / agent working files
.claude/
.serena/
.remember/
.opencode/

# Generated key-provisioning output — must never be included in context
/provisioning/

# Defense in depth: any private-key-shaped file, anywhere in the repo
*.key
*.pem
*-private
*-private.*
*_private_key*
*.priv
